generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contract {
  id             Int       @id @default(autoincrement())
  contractNumber String    @map("contract_number")
  customerName   String    @map("customer_name")
  kostenplaats   String?
  description    String?
  startDate      DateTime  @db.Date @map("start_date")
  endDate        DateTime? @db.Date @map("end_date")
  contractValue    Float?    @map("contract_value")
  m2               Float?    @map("m2")
  pricePerM2       Float?    @map("price_per_m2")
  priceIndex       Float?    @map("price_index")
  basePricePerM2   Float?    @map("base_price_per_m2")
  baseIndexYear    Int?      @map("base_index_year")
  indexSeries      String?   @map("index_series")
  contractType     String?   @map("contract_type")
  invoiceFrequency String?   @map("invoice_frequency")
  manager          String?   @map("manager")
  invoiceStartDate DateTime? @db.Date @map("invoice_start_date")
  invoiceEndDate   DateTime? @db.Date @map("invoice_end_date")
  debiteurnummer   String?   @map("debiteurnummer")
  kadastrale       String?   @map("kadastrale")
  grootboekNieuw   String?   @map("grootboek")
  grootboekOud     String?   @map("grootboek_oud")
  btwCode          String?   @map("btw_code")
  invoiceRef       String?   @map("invoice_ref")
  fixedPrice       Boolean   @default(false) @map("fixed_price")
  status           String    @default("draft")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("contracts")
}

model BtwCode {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  description String
  percentage  Float?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("btw_codes")
}

model Customer {
  id                Int      @id @default(autoincrement())
  debiteurnummer    String   @unique @map("debiteurnummer")
  debiteurnummerOud String?  @map("debiteurnummer_oud")
  name              String
  address        String?
  city           String?
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("customers")
}
